@page
@model AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="section">
    <div class="container">
        <h2 class="section-title">About PAL Building Material</h2>

        <div class="about-box reveal">

            <p>
                PAL Building Material is a trusted building material supplier located at
                Pant Nagar, Ghatkopar East, Mumbai. With over 30+ years of experience,
                we provide high-quality construction materials for homes, shops,
                contractors, builders, and renovation projects.
            </p>

            <p>
                We deal in cement, bricks, sand (Reti), khadi (aggregate), steel,
                tiles, plumbing, electrical materials, paint items, and hardware products.
            </p>

            <p>
                Our focus is on genuine materials, fair pricing, fast delivery,
                and long-term customer relationships.
            </p>

            <hr style="margin:25px 0;" />

            <h3>Business Details</h3>

            <p><strong>Owner:</strong> XXXXXXXXXXX</p>

            <p><strong>GST Number:</strong> 27XXXXXXXXXXZ5</p>

            <p>
                <strong>Address:</strong><br />
                3WM8+RH9,Kheteshwar Marg,<br />
                Pant Nagar,<br />
                Thane East, Mumbai,<br />
                Maharashtra 400009
            </p>

        </div>
    </div>
</section>

