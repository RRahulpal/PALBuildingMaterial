@page
@model AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="section">
    <div class="container">
        <h2 class="section-title">About PAL Building Material</h2>

        <div class="about-box">
            <p>
                PAL Building Material is a local building material shop located
                at PantNagar, Ghatkopar. We supply quality construction materials
                for homes, shops, contractors, builders and renovation projects.
            </p>

            <p>
                Our shop deals in cement, bricks, sand, steel, tiles, plumbing,
                electrical material, paint items, hardware and other construction
                essentials.
            </p>

            <p>
                We focus on genuine material, fair pricing, fast delivery and
                customer satisfaction.
            </p>
        </div>
    </div>
</section>