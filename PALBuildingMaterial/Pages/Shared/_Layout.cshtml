<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - PAL Building Material</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="~/css/site.css" rel="stylesheet" />
    <meta name="description" content="PAL Building Material - 30+ years trusted shop in Pant Nagar Ghatkopar. Cement, sand, bricks, steel, tiles, plumbing, electrical and hardware materials available at best price." />

    <meta name="keywords" content="building material Ghatkopar, cement shop Mumbai, sand supplier Pant Nagar, bricks supplier, steel TMT Mumbai, hardware shop Ghatkopar" />

    <meta name="author" content="PAL Building Material" />
    <!-- 🔥 OPEN GRAPH -->
    <meta property="og:title" content="PAL Building Material" />
    <meta property="og:description" content="Trusted building material supplier in Ghatkopar for 30+ years." />
    <meta property="og:image" content="https://palbuildingmaterial-1.onrender.com/Images/logo.png" />
    <meta property="og:url" content="https://palbuildingmaterial-1.onrender.com" />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="1fUeqXMfubtNZK9nTswIvp7c_bWkCzWIh3phXMExXNk" />
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "HardwareStore",
          "name": "PAL Building Material",
         "image": "https://palbuildingmaterial-1.onrender.com/Images/logo.png"
          "address": {
            "@@type": "PostalAddress",
            "streetAddress": "Pant Nagar",
            "addressLocality": "Ghatkopar",
            "addressRegion": "Mumbai",
            "postalCode": "400075",
            "addressCountry": "IN"
          },
          "telephone": "+91 9892581080"
        }
    </script>
</head>
<body>

    <!-- 🔥 Loader START -->
    <div id="loader">
        <div class="loader-box">
            <img src="~/Images/logo.png" alt="PAL Logo" />
            <p>Loading PAL Building Material...</p>
        </div>
    </div>
    <!-- 🔥 Loader END -->
    <header class="topbar">
        <div class="container topbar-inner">
            <span>📞 +91 98925 81080</span>
            <span>📍 Pant Nagar, Ghatkopar</span>
            <span>🕘 9:00 AM - 6:00 PM</span>
        </div>
    </header>

    <header class="header">
        <div class="container nav">
            <a asp-page="/Index" class="brand">
               @*  <div class="logo">
                    <span>PAL</span>
                    <small>BM</small>
                </div> *@
                <img src="~/Images/logo.png" alt="PAL Logo" class="logo-img" />
                <div>
                    <h2>PAL Building Material</h2>
                    <p>Trusted for 30+ Years</p>
                </div>
            </a>

            <button class="menu-btn" onclick="toggleMenu()">☰</button>

            <nav id="menu">
                <a asp-page="/Index">Home</a>
                <a asp-page="/Products">Products</a>
                <a asp-page="/About">About</a>
                <a asp-page="/Contact">Contact</a>
                <a asp-page="/Cart" class="cart-link">🛒 Quote Cart</a>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container footer-grid">
            <div>
                <h3>PAL Building Material</h3>
                <p>30+ years trusted building material supplier in PantNagar, Ghatkopar.</p>
            </div>
            <div>
                <h4>Quick Links</h4>
                <a asp-page="/Products">Products</a>
                <a asp-page="/Contact">Get Quote</a>
                <a asp-page="/About">About Us</a>
            </div>
            <div>
                <h4>Contact</h4>
                <p>📞 +91 98925 81080</p>
                <p>📍 Pant Nagar, Ghatkopar East Mumbai: 400075</p>
            </div>
        </div>
        <div class="copyright">© @DateTime.Now.Year PAL Building Material</div>
    </footer>

    <script>
              const revealElements = document.querySelectorAll(".reveal");

        function revealOnScroll() {
            revealElements.forEach(el => {
                const windowHeight = window.innerHeight;
                const elementTop = el.getBoundingClientRect().top;

                if (elementTop < windowHeight - 80) {
                    el.classList.add("active");
                }
            });
        }

        window.addEventListener("scroll", revealOnScroll);
        window.addEventListener("load", revealOnScroll);
              // 🔥 Loader hide
        window.addEventListener("load", function () {
            document.getElementById("loader").style.display = "none";
        });

        function toggleMenu() {
            document.getElementById("menu").classList.toggle("show");
        }
    </script>
    <a href="https://wa.me/918104881897" class="whatsapp-float" target="_blank">
        <img src="~/Images/whatsapp.png" alt="WhatsApp" />
    </a>
</body>
</html>